# 途牛
TUNIU_API_KEY=

# 飞书多维表格（可选）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_TOKEN=
FEISHU_TABLE_ID=
FEISHU_BASE_URL=

# 管理后台 API 密钥（会员与积分配置）
ADMIN_SECRET=tomato-admin-dev

# 管理员登录账号（请修改为真实账号，切勿提交真实值到 Git）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_strong_password_here

# 即梦 / Dreamina CLI
JIMENG_BIN=dreamina
# JIMENG_IMAGE_ARGS 为 JSON 数组，可用 __PROMPT__ 占位，例如：
# JIMENG_IMAGE_ARGS=["image-generate","--prompt","__PROMPT__","--json"]

# 美图 OpenAPI（meitu-cli，勿将真实 Key 提交到 Git）
MEITU_BIN=meitu
MEITU_OPENAPI_ACCESS_KEY=
MEITU_OPENAPI_SECRET_KEY=

# 服务
PORT=3000
HOST=127.0.0.1
